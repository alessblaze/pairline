# Frontend Configuration

# API Endpoints
# Go backend (Moderation API, admin API, TURN)
VITE_API_URL=http://localhost:8082
# Erlang backend (WebSocket for video chat)
VITE_WS_URL=ws://localhost:8080/ws

# CORS / Allowed Hosts (comma-separated)
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,.local

# WebRTC Configuration
# Optional: STUN servers (comma separated)
VITE_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun.cloudflare.com:3478
# TURN mode:
# - auto: let the backend choose off / cloudflare / integrated
# - off: skip TURN bootstrap entirely and stay STUN-only
# - cloudflare: keep using the backend bootstrap endpoint, expecting Cloudflare relay config
# - integrated: keep using the backend bootstrap endpoint, expecting Pairline-managed TURN relay config
VITE_TURN_MODE=auto
# Deprecated compatibility flag. Prefer VITE_TURN_MODE.
VITE_ENABLE_TURN=true
VITE_FORCE_RELAY=false
VITE_WEBRTC_DEBUG=true
VITE_WEBSOCKET_DEBUG=false

#Turnstile
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Features
VITE_ENABLE_VIDEO_CHAT=true

# Legal URLs
VITE_TERMS_URL=https://example.com/terms
VITE_PRIVACY_URL=https://example.com/privacy
